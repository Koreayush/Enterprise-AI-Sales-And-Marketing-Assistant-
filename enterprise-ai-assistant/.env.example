# --- LLM Provider (choose one) ---
# Required if LLM_PROVIDER=openai (default)
OPENAI_API_KEY=your_openai_key_here

# Required if LLM_PROVIDER=groq (free alternative)
GROQ_API_KEY=your_groq_key_here

# Which LLM backend to use: "openai" or "groq"
LLM_PROVIDER=openai

# --- Embeddings ---
# Which embedding backend to use: "openai" (default, needs OPENAI_API_KEY)
# or "huggingface" (free, local, needs `pip install sentence-transformers`)
EMBEDDING_PROVIDER=openai

# --- Retrieval tuning ---
# BM25_WEIGHT + VECTOR_WEIGHT should sum to 1.0
# Default [0.4, 0.6] favors semantic search; use [0.6, 0.4] for keyword-heavy data
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# --- Storage paths ---
DATA_DIR=data
CHROMA_PERSIST_DIR=chroma_db
